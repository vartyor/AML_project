# ──────────────────────────────────────────────────────
# Streamlit Cloud 시크릿 설정 예시
# 실제 값은 Streamlit Cloud 대시보드 > App settings > Secrets에 입력
# 이 파일(.example)만 git 추적, 실제 secrets.toml은 .gitignore에서 제외
#
# 무료 키 발급:
#   Groq  → https://console.groq.com
# ──────────────────────────────────────────────────────

[groq]
# SAR 보고서 LLM 생성에 사용됩니다.
# 무료 플랜: 14,400 req/day, 30 req/min
api_key = "gsk_..."

[neo4j]
# GraphRAG 기능 사용 시 Neo4j AuraDB 또는 외부 Neo4j 서버 정보 입력
# 미설정 시 GraphRAG 기능만 비활성화됩니다.
uri      = "bolt://your-neo4j-host:7687"
username = "neo4j"
password = "your-password"
