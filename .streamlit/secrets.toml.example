# ──────────────────────────────────────────────────────
# HF Spaces / Streamlit Cloud 시크릿 설정 예시
# 실제 값은 HF Spaces > Settings > Repository secrets 에 입력
# 이 파일(.example)만 git 추적, 실제 secrets.toml은 .gitignore에서 제외
#
# 무료 키 발급:
#   Groq      → https://console.groq.com
#   Neo4j AuraDB Free → https://console.neo4j.io
# ──────────────────────────────────────────────────────

[groq]
# SAR 보고서 LLM 생성에 사용됩니다.
# 무료 플랜: 14,400 req/day, 30 req/min
api_key = "gsk_..."

[neo4j]
# Neo4j AuraDB Free 인스턴스 정보 입력 (GraphRAG 활성화)
# 미설정 시 GraphRAG 기능만 비활성화됩니다 (Graceful Degradation).
#
# AuraDB URI 형식: neo4j+s://xxxxxxxx.databases.neo4j.io
# ※ 로컬 bolt:// 와 달리 TLS 내장 프로토콜이므로 포트 번호 불필요
uri      = "neo4j+s://xxxxxxxx.databases.neo4j.io"
username = "neo4j"
password = "your-aura-password"
